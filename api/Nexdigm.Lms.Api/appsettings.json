{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "LmsLogging": {
    "Level": "Info",
    "Directory": "logs",
    "DatabaseErrors": true
  },

  "Database": {
    "Provider": "SqlServer",
    "AllowSqliteFallback": false
  },

  "ConnectionStrings": {
    "SqlServer": "Server=(localdb)\\MSSQLLocalDB;Database=NexdigmLMS;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "Sqlite": "Data Source=nexdigm-lms.db"
  },

  "Jwt": {
    "Issuer": "Nexdigm.Lms",
    "Audience": "Nexdigm.Lms.Web",
    "Key": "CHANGE-ME-IN-PRODUCTION-nexdigm-lms-dev-signing-key-0123456789",
    "ExpiryMinutes": 480,
    "IdleTimeoutMinutes": 30
  },

  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173", "http://localhost:4173" ]
  },

  "Ingestion": {
    "ApiKey": "marketradmin-dev-key-change-me"
  },

  "Email": {
    "Enabled": false,
    "SmtpHost": "",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "FromAddress": "lms-notifications@nexdigm.com",
    "FromName": "Nexdigm LMS"
  },

  "BulkUpload": {
    "DuplicateWindowDays": 7
  },

  "Notifications": {
    "DailyRunHourIst": 18,
    "AgingReminderDays": 5,
    "EscalationDays": 10,
    "DemoIntervalMinutes": 0
  },

  "Seed": {
    "Enabled": true,
    "SampleLeads": true
  }
}
